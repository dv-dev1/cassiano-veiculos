# Supabase — copie para .env.local e preencha com as chaves do seu projeto.
# Pegue em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (NUNCA expor no cliente — só usada no admin/server).
SUPABASE_SERVICE_ROLE_KEY=

# Contato da loja (usado no site: botão WhatsApp, links).
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_INSTAGRAM_URL=
